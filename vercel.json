{
  "rewrites": [
    { "source": "/((?!api|assets|aero\\.html|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-Requested-With"
        }
      ]
    }
  ],
  "functions": {
    "api/zk/process-pending-exchanges.ts": { "maxDuration": 300 },
    "api/zk/process-split-queue.ts": { "maxDuration": 120 },
    "api/zk/auto-split-and-exchange.ts": { "maxDuration": 120 }
  },
  "crons": [
    { "path": "/api/zk/process-pending-exchanges", "schedule": "*/2 * * * *" }
  ]
}
